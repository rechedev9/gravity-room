# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ Gravity Room — environment surface (serverless / Vercel same-origin)        ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║ The product is ONE same-origin Vercel project: the Vite/React PWA ships as  ║
# ║ static output and calls same-origin /api, while the Elysia API runs as a    ║
# ║ Node serverless function (api/[...path].ts). Set Production + Preview vars   ║
# ║ in the Vercel dashboard; this file is the local-dev template. See the full  ║
# ║ go-live procedure in docs/VERCEL_CUTOVER.md.                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Required: Database (Neon Postgres) ──────────────────────────────────────

# Pooled PgBouncer endpoint. The serverless DB client opens at most ONE
# connection per warm instance (pool max=1, prepare:false), so this MUST be the
# Neon *pooled* connection string (host contains "-pooler"). Used at request time.
DATABASE_URL=postgresql://postgres:password@localhost:5432/gzclp

# Direct (non-pooled) Neon endpoint. Used ONLY by the build-time deploy step
# `bun run --filter api db:deploy` (drizzle migrations + idempotent seeds), which
# must run DDL serially against a direct connection — never PgBouncer. For local
# dev where you have a single endpoint you can omit this; db:deploy and
# drizzle.config.ts both fall back to DATABASE_URL.
# DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5432/gzclp

# TLS for the Postgres connection. Defaults to `require` when NODE_ENV=production
# (and off otherwise), so you normally never set this. Set DB_SSL=false ONLY for
# a local non-TLS Postgres you are running in production mode.
# DB_SSL=false

# ─── Required: Auth ──────────────────────────────────────────────────────────

# JWT signing secret — use a long random string (min 64 chars in production).
JWT_SECRET=dev-secret-change-me

# Google OAuth client ID (web).
GOOGLE_CLIENT_ID=<your-google-client-id>

# Comma-separated Google OAuth client IDs accepted by the mobile auth endpoints.
GOOGLE_CLIENT_IDS=<android-google-client-id>,<ios-google-client-id>,<web-google-client-id>

# ─── Required in production: State (Upstash Redis over REST) ──────────────────

# Per-instance state (presence, caches, rate limiting) lives in Upstash Redis via
# the connectionless @upstash/redis REST client. BOTH vars are MANDATORY in
# production: the API throws at cold start if either is missing while
# NODE_ENV=production. When unset in local dev, presence/caches/rate-limiting
# degrade gracefully (no-op / cache miss).
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<upstash-rest-token>

# ─── Required in production: Internal / cron auth ────────────────────────────

# Shared Bearer secret guarding the manual ops path of /api/internal/* routes
# (cleanup-tokens, purge-users, analytics/compute). Presented as
# `Authorization: Bearer <secret>` or `x-internal-secret: <secret>`. The guard
# fails closed: if neither INTERNAL_SECRET nor CRON_SECRET is set, every internal
# request is rejected 401. Set this in production for manual operator invocations.
# INTERNAL_SECRET=<long-random-secret>

# CRON_SECRET is REQUIRED in production. Vercel Cron injects it automatically:
# when this env var is set on the Vercel project, Vercel sends
# `Authorization: Bearer <CRON_SECRET>` on every scheduled cron invocation, which
# the internal routes accept. Without it EVERY scheduled cron request gets 401
# and cleanup/purge/analytics silently stop running. You only set the *value* in
# Vercel; it is not needed for local dev.
# CRON_SECRET=<vercel-cron-bearer-secret>

# ─── Network (same-origin) ───────────────────────────────────────────────────

# Allowed CORS origin for the web frontend. LEAVE EMPTY for the same-origin
# Vercel deployment — the SPA and API share an origin, so no CORS is needed and
# an empty value means "no cross-origin allowed" in production. Set a value only
# for split-origin local dev (e.g. the Vite dev server on another port).
CORS_ORIGIN=

# API port for the LOCAL dev server (src/dev-server.ts) only. Ignored on Vercel.
PORT=3001

# Trust X-Forwarded-For for rate-limit keying. Recommended `true` on Vercel so
# the real client IP (left-most XFF entry the platform injects) is used; without
# it the serverless runtime reports the IP as 'unknown'.
# TRUSTED_PROXY=true

# Access-token lifetime (default: 15m).
# JWT_ACCESS_EXPIRY=15m

# ─── Optional: Analytics cron ────────────────────────────────────────────────

# Bounded batch size processed per /api/internal/analytics/compute cron tick
# (least-recently-computed users). Default: 50.
# ANALYTICS_BATCH_SIZE=50

# ─── Optional: Observability ─────────────────────────────────────────────────

# Sentry DSN for @sentry/node error + performance tracing (leave empty locally).
# Pull-based Prometheus and /metrics were removed; logs are pino JSON to Vercel.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# pino log level: debug | info | warn | error (default: info).
# LOG_LEVEL=info

# ─── Optional: Admin ─────────────────────────────────────────────────────────

# Comma-separated UUIDs of admin users (for program definition approval).
# ADMIN_USER_IDS=

# ─── Optional: Telegram Notifications ────────────────────────────────────────

# Bot token from @BotFather and chat ID for new-user alerts.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── REMOVED (do not reintroduce) ────────────────────────────────────────────
# REDIS_URL              → replaced by UPSTASH_REDIS_REST_URL/_TOKEN (REST client).
# METRICS_TOKEN          → /metrics + prom-client deleted; use Sentry + pino logs.
# DB_POOL_SIZE           → pool now defaults to max=1 for the pooled endpoint.
# COMPUTE_INTERVAL_HOURS → analytics scheduling is now a Vercel Cron declaration.

# ─── Web (apps/frontend/web, Vite build-time) ────────────────────────────────

# API base URL baked into the SPA at build time. Set to "" (empty) for the
# same-origin Vercel deployment so the SPA issues relative /api requests. The
# production Vercel build (scripts/vercel-build.sh) already exports VITE_API_URL=""
# for you. For split-origin local dev, point it at the local API instead.
VITE_API_URL=

# Google OAuth web client ID. REQUIRED for web Google sign-in — the SPA reads
# import.meta.env.VITE_GOOGLE_CLIENT_ID at build time. Use the same web client ID
# as the API's GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>

# Optional: Sentry DSN for the web client (browser error + performance tracing).
# VITE_SENTRY_DSN=

# Optional: Plausible analytics domain for the web client.
# VITE_PLAUSIBLE_DOMAIN=

# ─── Mobile (apps/frontend/mobile, Expo) ─────────────────────────────────────

# Production mobile builds must point at the deployed same-origin Vercel domain.
# Replace the placeholder below with the real domain after the first Vercel
# deploy (this is a required cutover step). For local development against a dev
# API, set EXPO_PUBLIC_API_URL=http://localhost:3001 instead.
EXPO_PUBLIC_API_URL=https://YOUR-APP.vercel.app
EXPO_PUBLIC_GOOGLE_CLIENT_ID=<optional-fallback-google-client-id>
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<android-google-client-id>
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<ios-google-client-id>
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<web-google-client-id>
