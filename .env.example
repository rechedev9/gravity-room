# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/gzclp

# JWT signing secret — use a long random string (min 64 chars in production)
JWT_SECRET=dev-secret-change-me

# Google OAuth client ID
GOOGLE_CLIENT_ID=<your-google-client-id>

# Comma-separated Google OAuth client IDs accepted by the mobile auth endpoints
GOOGLE_CLIENT_IDS=<android-google-client-id>,<ios-google-client-id>,<web-google-client-id>

# ─── Network ─────────────────────────────────────────────────────────────────

# Allowed CORS origin for the web frontend
CORS_ORIGIN=http://localhost:5173

# API port (default: 3001)
PORT=3001

# Set to true when behind a reverse proxy (reads X-Forwarded-For for rate limiting)
# TRUSTED_PROXY=true

# ─── Optional: Redis ─────────────────────────────────────────────────────────

# When unset, rate limiting and presence tracking use in-memory stores (reset on restart)
# REDIS_URL=redis://localhost:6379

# ─── Optional: Monitoring ────────────────────────────────────────────────────

# Sentry DSN for error tracking (leave empty in development)
# SENTRY_DSN=

# Bearer token for GET /metrics endpoint (required in production)
# METRICS_TOKEN=

# slog log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ─── Optional: Admin ─────────────────────────────────────────────────────────

# Comma-separated UUIDs of admin users (for program definition approval)
# ADMIN_USER_IDS=

# ─── Optional: Telegram Notifications ────────────────────────────────────────

# Bot token from @BotFather and chat ID for new-user alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Web (apps/web) ─────────────────────────────────────────────────────────

# API base URL baked into the SPA at build time
VITE_API_URL=http://localhost:3001

# Mobile (apps/mobile)
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_GOOGLE_CLIENT_ID=<optional-fallback-google-client-id>
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<android-google-client-id>
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<ios-google-client-id>
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<web-google-client-id>
