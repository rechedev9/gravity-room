{
  "name": "gravity-room",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/backend/*",
    "apps/frontend/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "dev:web": "bun run --filter web dev",
    "dev:api": "bun run --filter api dev",
    "build": "bun run --filter web build",
    "build:ci": "VITE_API_URL=${VITE_API_URL:-http://localhost:3001} bun run build",
    "build:web": "bun run --filter web build",
    "typecheck": "bun run --filter web typecheck && bun run typecheck:domain && bun run typecheck:database && bun run typecheck:api-client && bun run typecheck:mobile",
    "typecheck:api": "bun run --filter api typecheck",
    "typecheck:domain": "bun run --filter @gzclp/domain typecheck",
    "typecheck:api-client": "bun run --filter @gzclp/api-client typecheck",
    "typecheck:mobile": "bun run --filter mobile typecheck",
    "lint": "bun run --filter web lint && bun run --filter api lint && bun run lint:api-client",
    "lint:api-client": "bun run --filter @gzclp/api-client lint",
    "lint:fix": "bun run --filter web lint:fix && bun run --filter api lint:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "bun run --filter web test && bun run test:domain && bun run test:database && bun run test:api-client && bun run test:mobile",
    "test:api": "bun run --filter api test",
    "test:domain": "bun run --filter @gzclp/domain test",
    "test:api-client": "bun run --filter @gzclp/api-client test",
    "test:mobile": "bun run --filter mobile test",
    "security:headers": "bun run scripts/check-security-headers.ts",
    "e2e": "bun run --filter web e2e",
    "e2e:ui": "bun run --filter web e2e:ui",
    "e2e:headed": "bun run --filter web e2e:headed",
    "hooks:validate": "lefthook validate",
    "ci": "bun run typecheck && bun run typecheck:api && bun run lint && bun run format:check && bun run test && bun run build:ci",
    "context:refresh": "bun run scripts/refresh-claude-context.ts",
    "typecheck:database": "bun run --filter @gzclp/database typecheck",
    "test:database": "bun run --filter @gzclp/database test",
    "db:generate": "bun run --filter @gzclp/database db:generate",
    "db:migrate": "bun run --filter @gzclp/database db:migrate",
    "db:studio": "bun run --filter @gzclp/database db:studio"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "trustedDependencies": [
    "lefthook"
  ],
  "overrides": {
    "axios": ">=1.15.1",
    "vite": ">=7.3.2",
    "rollup": ">=4.59.0",
    "happy-dom": ">=20.8.9",
    "serialize-javascript": ">=7.0.3",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "brace-expansion": ">=5.0.6",
    "ws": ">=8.21.0",
    "uuid": ">=11.1.1",
    "@babel/plugin-transform-modules-systemjs": ">=7.29.7",
    "follow-redirects": ">=1.15.12",
    "fast-uri": ">=3.1.1",
    "esbuild": ">=0.25.0",
    "flatted": ">=3.4.0",
    "@tootallnate/once": ">=3.0.1",
    "shell-quote": ">=1.8.4"
  }
}
