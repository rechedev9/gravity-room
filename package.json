{
  "name": "gravity-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter web build",
    "build:ci": "cross-env VITE_API_URL=http://localhost:3001 pnpm run build",
    "build:ci:no-prerender": "cross-env VITE_API_URL=http://localhost:3001 pnpm --filter web build:no-prerender",
    "build:web": "pnpm --filter web build",
    "typecheck": "pnpm --filter web typecheck && pnpm run typecheck:domain && pnpm run typecheck:database && pnpm run typecheck:api-client && pnpm run typecheck:mobile",
    "typecheck:api": "pnpm --filter api typecheck",
    "typecheck:domain": "pnpm --filter @gzclp/domain typecheck",
    "typecheck:api-client": "pnpm --filter @gzclp/api-client typecheck",
    "typecheck:mobile": "pnpm --filter mobile typecheck",
    "lint": "pnpm --filter web lint && pnpm --filter api lint && pnpm run lint:api-client",
    "lint:api-client": "pnpm --filter @gzclp/api-client lint",
    "lint:fix": "pnpm --filter web lint:fix && pnpm --filter api lint:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm --filter web test && pnpm run test:domain && pnpm run test:database && pnpm run test:api-client && pnpm run test:mobile",
    "test:api": "pnpm --filter api test",
    "test:domain": "pnpm --filter @gzclp/domain test",
    "test:api-client": "pnpm --filter @gzclp/api-client test",
    "test:mobile": "pnpm --filter mobile test",
    "security:headers": "tsx scripts/check-security-headers.ts",
    "e2e": "pnpm --filter web e2e",
    "e2e:ui": "pnpm --filter web e2e:ui",
    "e2e:headed": "pnpm --filter web e2e:headed",
    "hooks:validate": "lefthook validate",
    "ci": "pnpm run hooks:validate && pnpm run typecheck && pnpm run typecheck:api && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build:ci",
    "context:refresh": "tsx scripts/refresh-claude-context.ts",
    "typecheck:database": "pnpm --filter @gzclp/database typecheck",
    "test:database": "pnpm --filter @gzclp/database test",
    "db:generate": "pnpm --filter @gzclp/database db:generate",
    "db:migrate": "pnpm --filter @gzclp/database db:migrate",
    "db:studio": "pnpm --filter @gzclp/database db:studio"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "tsx": "^4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
