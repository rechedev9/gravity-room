{
  "name": "gravity-room",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "dev:web": "bun run --filter web dev",
    "dev:api": "bun run --filter api dev",
    "build": "bun run --filter web build",
    "build:web": "bun run --filter web build",
    "typecheck": "bun run --filter web typecheck",
    "typecheck:api": "bun run --filter api typecheck",
    "lint": "bun run --filter web lint",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "bun run --filter web test",
    "test:api": "bun run --filter api test",
    "e2e": "bun run --filter web e2e",
    "e2e:ui": "bun run --filter web e2e:ui",
    "e2e:headed": "bun run --filter web e2e:headed",
    "ci": "bun run typecheck && bun run typecheck:api && bun run lint && bun run format:check && bun run test && bun run build"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.166.13",
    "@types/bun": "^1.3.12",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "lefthook",
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-router": "^1.168.19",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2"
  }
}
