gravityroom.app {
    # Edge compression: zstd for modern browsers, gzip fallback. Origins
    # (nginx, ElysiaJS) return uncompressed content so Caddy can pick the
    # best encoding per Accept-Encoding header.
    encode zstd gzip

    @api path /api/* /health /metrics /swagger/*
    handle @api {
        reverse_proxy gravity-room-api:3001
    }
    handle {
        reverse_proxy gravity-room-web:80
    }
}
