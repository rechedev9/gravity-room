gravityroom.app {
    @api path /auth/* /catalog /catalog/* /programs /programs/* /program-definitions /program-definitions/* /exercises /exercises/* /muscle-groups /muscle-groups/* /stats /stats/* /health /metrics /swagger/*
    handle @api {
        reverse_proxy gzclp-api:3001
    }
    handle {
        reverse_proxy gzclp-web:80
    }
}
