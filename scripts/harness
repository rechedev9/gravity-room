#!/usr/bin/env bash
# Self-contained harness runner: starts the API, waits for health, runs contract tests, shuts down.
# Usage: scripts/harness
# Same entry point for local dev and CI — no separate behaviors.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
API_PORT="${API_PORT:-3001}"
BASE_URL="http://localhost:${API_PORT}"
MAX_WAIT_S=30
POLL_INTERVAL_S=0.5

# --- cleanup on exit ---
API_PID=""
cleanup() {
  if [ -n "$API_PID" ] && kill -0 "$API_PID" 2>/dev/null; then
    echo "[harness] stopping API (pid $API_PID)"
    kill "$API_PID" 2>/dev/null || true
    wait "$API_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

# --- start API in dev mode ---
echo "[harness] starting API on port ${API_PORT}"
cd "$REPO_ROOT"
PORT="$API_PORT" NODE_ENV=development LOG_LEVEL=silent bun run --filter api dev &
API_PID=$!

# --- wait for /health ---
echo "[harness] waiting for ${BASE_URL}/health (max ${MAX_WAIT_S}s)"
elapsed=0
while true; do
  if curl -sf "${BASE_URL}/health" > /dev/null 2>&1; then
    echo "[harness] API healthy"
    break
  fi
  # check if API process died
  if ! kill -0 "$API_PID" 2>/dev/null; then
    echo "[harness] API process exited unexpectedly"
    exit 1
  fi
  sleep "$POLL_INTERVAL_S"
  elapsed=$(echo "$elapsed + $POLL_INTERVAL_S" | bc)
  if [ "$(echo "$elapsed >= $MAX_WAIT_S" | bc)" -eq 1 ]; then
    echo "[harness] API did not become healthy within ${MAX_WAIT_S}s"
    exit 1
  fi
done

# --- run harness tests ---
echo "[harness] running contract tests"
cd "$REPO_ROOT"
BASE_URL="$BASE_URL" bun run --filter harness test:harness
EXIT_CODE=$?

echo "[harness] done (exit $EXIT_CODE)"
exit $EXIT_CODE
