# Production .env for VPS deploy — copy to /opt/gravity-room/.env on the host
# Set chmod 600 on the actual file. NEVER commit a populated copy.

# === Postgres (consumed by postgres service AND wired into DATABASE_URL) ===
POSTGRES_USER=gravity
POSTGRES_DB=gravity
POSTGRES_PASSWORD=<generate-strong-random-32+chars>

# === API runtime ===
DATABASE_URL=postgres://gravity:<same-password-as-above>@postgres:5432/gravity
REDIS_URL=redis://redis:6379
PORT=3001
TRUSTED_PROXY=true
CORS_ORIGIN=https://gravityroom.app
LOG_LEVEL=info

# === Auth (copy values from Railway env) ===
JWT_SECRET=<min-64-chars-random>
GOOGLE_CLIENT_ID=<web-google-client-id>
GOOGLE_CLIENT_IDS=<android>,<ios>,<web>

# === Optional ===
# SENTRY_DSN=
# METRICS_TOKEN=
# ADMIN_USER_IDS=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# INTERNAL_SECRET=<for-analytics-/compute-endpoint>
