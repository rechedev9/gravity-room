# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/gzclp

# --- Auth ---
JWT_SECRET=<min-64-char-random-string>
GOOGLE_CLIENT_ID=<google-oauth-client-id>

# --- Network ---
CORS_ORIGIN=https://yourdomain.app
PORT=3001
TRUSTED_PROXY=true

# --- Optional: Redis ---
# REDIS_URL=redis://host:6379

# --- Optional: Monitoring ---
# SENTRY_DSN=
# METRICS_TOKEN=
# LOG_LEVEL=info

# --- Optional: Admin ---
# ADMIN_USER_IDS=<comma-separated-uuids>
