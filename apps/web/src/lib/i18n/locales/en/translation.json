        "refresh_token_duration": "7 days",
        "refresh_token_owner": "Gravity Room (first-party)"
      },
      "third_party": {
        "title": "Third-party cookies",
        "body_prefix": "When using Google sign-in, Google's service may set its own cookies during the authentication process. These cookies are managed by Google and subject to their",
