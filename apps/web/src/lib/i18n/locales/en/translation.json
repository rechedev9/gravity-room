        "no_access": "Gravity Room does not control or have access to such cookies."
      },
      "local_storage": {
        "title": "Local storage",
        "body": "In addition to the cookie mentioned above, Gravity Room uses browser local storage to save display preferences and training data in guest mode. This data is never sent to any server and can be deleted by clearing your site data in your browser."
      },
      "analytics": {
        "title": "Analytics",
        "body": "a privacy-friendly web analytics service. Plausible does not use cookies, does not collect identifiable personal data, and does not track users between sessions. Aggregated data (page views, country of origin, device type) is used solely to improve the service."
      },
      "legal_basis": {
        "title": "Legal basis",
        "body": "is exempt from prior consent under article 22.2 of Law 34/2002 (LSSI-CE), as it is strictly necessary for the provision of the authentication service expressly requested by the user. This exemption is also recognized by Recital 66 of Directive 2009/136/EC and the guidelines of the European Data Protection Board."
      },
      "disable_cookies": {
