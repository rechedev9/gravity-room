  "legal": {
    "back": "← Back",
    "privacy": {
      "document_title": "Privacy Policy — Gravity Room",
      "title": "Privacy Policy",
      "data_stored": {
        "title": "Data We Store",
        "body": "All training data (exercises, weights, sets, repetitions, and results) is stored locally in your browser's localStorage. This data never leaves your device unless you explicitly enable cloud sync."
      },
      "cloud_sync": {
        "title": "Cloud Sync (Optional)",
        "body": "If you create an account, we store your email address and training data in a secure database (PostgreSQL). This allows synchronization between devices. Cloud sync is completely optional — the app works fully offline without an account."
      },
      "google_login": {
        "title": "Google Sign-In (Optional)",
        "body": "If you sign in with Google, we receive your email address and profile name from Google. We do not access your contacts, calendar, or any other Google data."
      },
      "cookies": {
        "title": "Cookies, Analytics, and Tracking",
        "body_prefix": "We only use a technical cookie necessary to maintain authenticated user sessions. We do not use analytics, tracking, or advertising cookies. No data is shared with advertisers or third parties. See our",
        "link": "Cookie Policy",
        "body_suffix": "for more information."
      },
      "delete_data": {
        "title": "Delete Your Data",
        "local_label": "Local data:",
        "local_body": "Clear your browser's localStorage or use the \"Reset All\" option in the app.",
        "cloud_label": "Cloud data:",
        "cloud_body": "If you have an account and wish to delete your cloud data, contact us and we will delete your account and all associated data from our database."
      },
      "contact": {
        "title": "Contact",
        "body": "For privacy questions or data deletion requests, open an issue on the project repository or contact the maintainer."
      }
    },
    "cookie_policy": {
      "document_title": "Cookie Policy — Gravity Room",
      "title": "Cookie Policy",
      "what_are_cookies": {
        "title": "What are cookies?",
        "body": "Cookies are small text files that websites store in your browser. They may be necessary for the technical functioning of the site or used for analytical or advertising purposes."
      },
      "which_cookies": {
        "title": "What cookies does Gravity Room use?",
        "body": "Gravity Room only uses a technical cookie strictly necessary for authentication functionality.",
        "no_tracking": "We do not use analytics, advertising, or tracking cookies of any kind."
      },
      "table": {
        "name": "Name",
        "type": "Type",
        "purpose": "Purpose",
        "duration": "Duration",
        "owner": "Owner",
        "technical_type": "Technical (necessary)",
