{
  "name": "mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "test": "bunx jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@gzclp/domain": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "expo": "^55.0.17",
    "expo-auth-session": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.5",
    "react-native": "0.85.2",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.2",
    "babel-preset-expo": "^55.0.18",
    "jest": "^30.3.0",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "19.2.5"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|.bun|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base))",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  }
}
