{
  // Expo requires its tsconfig.base for module resolution (moduleResolution: "node")
  // and bundler configuration specific to Metro. Overriding these would break
  // the Expo/Metro build pipeline. See: https://docs.expo.dev/guides/typescript/
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Needed to import the i18n locale catalogs as typed JSON modules. Safe to
    // set here: it does not touch the Metro-critical moduleResolution/module.
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["jest", "react", "react-native"],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
