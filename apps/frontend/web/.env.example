VITE_API_URL=http://localhost:3001
VITE_GOOGLE_CLIENT_ID= # Optional. Google OAuth client ID for Google Sign-In.
VITE_AUTH_APPLE_ENABLED=false # Optional. Shows Apple redirect button when backend Apple auth is configured.
VITE_AUTH_GITHUB_ENABLED=false # Optional. Shows GitHub redirect button when backend GitHub auth is configured.
VITE_SENTRY_DSN= # Optional. Sentry DSN for browser error tracking. Leave empty in development.
VITE_PLAUSIBLE_DOMAIN= # Optional. Plausible Analytics domain (e.g. gravityroom.app). Leave empty to disable.
VITE_DEV_AUTH_SECRET= # DEV-only. Secret for the in-app "Dev Login" button; must match the API's AUTH_DEV_ROUTE_SECRET. Defaults to e2e-dev-secret-not-for-prod. Stripped from production builds.
