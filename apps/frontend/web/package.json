{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "tsx scripts/generate-sitemap.ts && vite build && tsx scripts/prerender.ts",
    "build:no-prerender": "vite build",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "api:types": "tsx codegen/generate-api-types.ts",
    "verify:citations": "tsx scripts/verify-citations.ts",
    "preview": "vite preview --host 127.0.0.1 --port 5173 --strictPort"
  },
  "dependencies": {
    "@gzclp/api-client": "workspace:*",
    "@gzclp/domain": "workspace:*",
    "@gzclp/database": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-oauth/google": "^0.13.4",
    "@sentry/react": "^10.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.168.19",
    "clsx": "^2.1.1",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "motion": "^12.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "tailwindcss": "^4",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@happy-dom/global-registrator": "^20.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "openapi-zod-client": "^1.18.3",
    "happy-dom": "^15",
    "tsx": "^4",
    "vitest": "^2"
  }
}
