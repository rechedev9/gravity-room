{
  "openapi": "3.0.3",
  "info": {
    "title": "Gravity Room API",
    "description": "REST API for the Gravity Room strength training tracker.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:3001", "description": "Local development" }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication and user management" },
    { "name": "Programs", "description": "Program instance CRUD" },
    { "name": "Results", "description": "Workout result recording and undo" },
    { "name": "Catalog", "description": "Public program catalog" },
    { "name": "Exercises", "description": "Exercise and muscle group catalog" },
    { "name": "Program Definitions", "description": "User-created program definitions" },
    { "name": "System", "description": "Health, metrics, and diagnostics" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error", "code"],
        "properties": {
          "error": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": ["id", "email", "name", "avatarUrl"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": ["user", "accessToken"],
        "properties": {
          "user": { "$ref": "#/components/schemas/UserResponse" },
          "accessToken": { "type": "string" }
        }
      },
      "RefreshResponse": {
        "type": "object",
        "required": ["accessToken"],
        "properties": {
          "accessToken": { "type": "string" }
        }
      },
      "ProgramInstanceResponse": {
        "type": "object",
        "required": ["id", "programId", "name", "config", "metadata", "status", "results", "undoHistory", "resultTimestamps", "completedDates", "definitionId", "customDefinition", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "programId": { "type": "string" },
          "name": { "type": "string" },
          "config": { "type": "object", "description": "Program configuration (JSONB)" },
          "metadata": { "description": "Arbitrary metadata (JSONB)", "nullable": true },
          "status": { "type": "string", "enum": ["active", "completed", "archived"] },
          "results": { "type": "object", "additionalProperties": true },
          "undoHistory": { "type": "array", "items": { "type": "object" } },
          "resultTimestamps": { "type": "object", "additionalProperties": { "type": "string" } },
          "completedDates": { "type": "object", "additionalProperties": { "type": "string" } },
          "definitionId": { "type": "string", "nullable": true },
          "customDefinition": { "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProgramInstanceListItem": {
        "type": "object",
        "required": ["id", "programId", "name", "status", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "programId": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "completed", "archived"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProgramListResponse": {
        "type": "object",
        "required": ["data", "nextCursor"],
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/ProgramInstanceListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        }
      },
      "CatalogEntry": {
        "type": "object",
        "required": ["id", "name", "description", "author", "category", "level", "source", "totalWorkouts", "workoutsPerWeek", "cycleLength"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "author": { "type": "string" },
          "category": { "type": "string" },
          "level": { "type": "string" },
          "source": { "type": "string" },
          "totalWorkouts": { "type": "integer" },
          "workoutsPerWeek": { "type": "integer" },
          "cycleLength": { "type": "integer" }
        }
      },
      "ExerciseEntry": {
        "type": "object",
        "required": ["id", "name", "muscleGroupId", "equipment", "isCompound", "isPreset", "createdBy", "force", "level", "mechanic", "category", "secondaryMuscles"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "muscleGroupId": { "type": "string" },
          "equipment": { "type": "string", "nullable": true },
          "isCompound": { "type": "boolean" },
          "isPreset": { "type": "boolean" },
          "createdBy": { "type": "string", "nullable": true },
          "force": { "type": "string", "nullable": true },
          "level": { "type": "string", "nullable": true },
          "mechanic": { "type": "string", "nullable": true },
          "category": { "type": "string", "nullable": true },
          "secondaryMuscles": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ExerciseListResponse": {
        "type": "object",
        "required": ["data", "total", "offset", "limit"],
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/ExerciseEntry" } },
          "total": { "type": "integer" },
          "offset": { "type": "integer" },
          "limit": { "type": "integer" }
        }
      },
      "MuscleGroupEntry": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "ProgramDefinitionResponse": {
        "type": "object",
        "required": ["id", "userId", "definition", "status", "createdAt", "updatedAt", "deletedAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "definition": { "type": "object", "description": "Program definition (JSONB)" },
          "status": { "type": "string", "enum": ["draft", "pending_review", "approved", "rejected"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deletedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ProgramDefinitionListResponse": {
        "type": "object",
        "required": ["data", "total"],
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/ProgramDefinitionResponse" } },
          "total": { "type": "integer" }
        }
      },
      "UndoResponse": {
        "type": "object",
        "required": ["undone"],
        "properties": {
          "undone": { "nullable": true, "description": "The undone entry, or null if nothing to undo" }
        }
      },
      "StatsOnlineResponse": {
        "type": "object",
        "required": ["count"],
        "properties": {
          "count": { "type": "integer", "nullable": true }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "timestamp", "uptime", "db", "redis"],
        "properties": {
          "status": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "uptime": { "type": "integer", "description": "Seconds since server start" },
          "db": { "type": "object" },
          "redis": { "type": "object" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "description": "Liveness probe — checks DB and Redis connectivity.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service healthy",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["System"],
        "summary": "Prometheus metrics",
        "description": "Returns Prometheus-formatted metrics. Protected by optional METRICS_TOKEN.",
        "operationId": "getMetrics",
        "security": [{ "bearerAuth": [] }, {}],
        "responses": {
          "200": { "description": "Prometheus metrics text" },
          "401": {
            "description": "Invalid metrics token",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/api/auth/google": {
      "post": {
        "tags": ["Auth"],
        "summary": "Google sign-in",
        "description": "Verify Google ID token and create or return user. Rate: 10/min per IP.",
        "operationId": "authGoogle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["credential"],
                "properties": { "credential": { "type": "string", "description": "Google ID token JWT" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Existing user signed in", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "201": { "description": "New user created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Missing credential", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid Google token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "429": { "description": "Rate limited", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/dev": {
      "post": {
        "tags": ["Auth"],
        "summary": "Dev login",
        "description": "Create or return test user by email. Development only — returns 404 in production.",
        "operationId": "authDev",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email" } }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created/returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "404": { "description": "Not available in production" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "description": "Rotate refresh token (httpOnly cookie) and issue new access token. Rate: 20/min per IP.",
        "operationId": "authRefresh",
        "responses": {
          "200": { "description": "Token refreshed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RefreshResponse" } } } },
          "401": { "description": "Invalid or expired refresh token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "429": { "description": "Rate limited", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/signout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign out",
        "description": "Revoke refresh token and clear cookie. Rate: 20/min per IP.",
        "operationId": "authSignout",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "Signed out" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user",
        "description": "Return the authenticated user's profile. Rate: 100/min per userId.",
        "operationId": "getMe",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "patch": {
        "tags": ["Auth"],
        "summary": "Update profile",
        "description": "Update user name and/or avatar. Rate: 20/min per IP.",
        "operationId": "updateMe",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "minLength": 1, "maxLength": 100, "nullable": true },
                  "avatarUrl": { "type": "string", "nullable": true, "description": "Base64 data URL (jpeg/png/webp, max 200KB)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserResponse" } } } },
          "400": { "description": "Invalid avatar", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Auth"],
        "summary": "Delete account",
        "description": "Soft-delete user account. Rate: 5/min per IP.",
        "operationId": "deleteMe",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "Account deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs": {
      "get": {
        "tags": ["Programs"],
        "summary": "List programs",
        "description": "List user's program instances with cursor-based pagination. Rate: 100/min per userId.",
        "operationId": "listPrograms",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Program list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "tags": ["Programs"],
        "summary": "Create program",
        "description": "Create a new program instance from a catalog program or definition. Rate: 20/min per userId.",
        "operationId": "createProgram",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "config"],
                "properties": {
                  "programId": { "type": "string", "description": "Catalog program ID (mutually exclusive with definitionId)" },
                  "definitionId": { "type": "string", "description": "User definition ID (mutually exclusive with programId)" },
                  "name": { "type": "string", "minLength": 1, "maxLength": 100 },
                  "config": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Program created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "422": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/import": {
      "post": {
        "tags": ["Programs"],
        "summary": "Import program",
        "description": "Import a previously exported program instance. Rate: 20/min per userId.",
        "operationId": "importProgram",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Program imported", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "422": { "description": "Invalid import data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/{id}": {
      "get": {
        "tags": ["Programs"],
        "summary": "Get program",
        "description": "Get program instance with all results. Rate: 100/min per userId.",
        "operationId": "getProgram",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Program detail", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "patch": {
        "tags": ["Programs"],
        "summary": "Update program",
        "description": "Update program name, status, or config. Rate: 20/min per userId.",
        "operationId": "updateProgram",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "minLength": 1, "maxLength": 100 },
                  "status": { "type": "string", "enum": ["active", "completed", "archived"] },
                  "config": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated program", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Programs"],
        "summary": "Delete program",
        "description": "Delete program instance and all results. Rate: 20/min per userId.",
        "operationId": "deleteProgram",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/{id}/metadata": {
      "patch": {
        "tags": ["Programs"],
        "summary": "Update program metadata",
        "description": "Replace program metadata (max 10KB). Rate: 20/min per userId.",
        "operationId": "updateProgramMetadata",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["metadata"],
                "properties": { "metadata": { "type": "object" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated program", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "400": { "description": "Metadata too large", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/{id}/export": {
      "get": {
        "tags": ["Programs"],
        "summary": "Export program",
        "description": "Export program instance as portable JSON. Rate: 20/min per userId.",
        "operationId": "exportProgram",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Exported program JSON", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/{id}/results": {
      "post": {
        "tags": ["Results"],
        "summary": "Record workout result",
        "description": "Record a result for a specific workout slot. Rate: 60/min per userId.",
        "operationId": "recordResult",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workoutIndex", "slotId", "result"],
                "properties": {
                  "workoutIndex": { "type": "integer", "minimum": 0 },
                  "slotId": { "type": "string" },
                  "result": { "type": "string" },
                  "amrapReps": { "type": "integer", "nullable": true },
                  "rpe": { "type": "integer", "nullable": true },
                  "setLogs": { "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Result recorded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramInstanceResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Program not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/programs/{id}/results/{workoutIndex}/{slotId}": {
      "delete": {
        "tags": ["Results"],
        "summary": "Delete result",
        "description": "Delete a specific workout result. Rate: 20/min per userId.",
        "operationId": "deleteResult",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "workoutIndex", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "slotId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Result deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
