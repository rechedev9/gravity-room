# Production .env for the api service. Copy to the host (e.g.
# /opt/gravity-room/.env on the VPS) and `chmod 600` it. NEVER commit a
# populated copy.
#
# This file MUST list every var with `requiredInProd: true` in
# src/lib/env-validation.ts — CI fails (validate.yml) if it drifts.
#
# Optional vars are kept commented for discoverability.

# ─── Required (api) ─────────────────────────────────────────────────────────

# PostgreSQL connection string. Boot-crashes the api if unset.
DATABASE_URL=postgres://gravity:CHANGE_ME@postgres:5432/gravity

# JWT signing secret. Must be >= 64 chars in production; >= 32 elsewhere.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-64-or-longer-random-string-generated-by-openssl-rand

# Web Google OAuth client ID. Throws per-request 500 when unset.
GOOGLE_CLIENT_ID=<web-google-client-id>.apps.googleusercontent.com

# Comma-separated Google OAuth client IDs accepted by mobile auth endpoints (android,ios,web).
GOOGLE_CLIENT_IDS=<android>.apps.googleusercontent.com,<ios>.apps.googleusercontent.com,<web>.apps.googleusercontent.com

# Bearer token for GET /metrics. Boot-crashes the api in production when unset (PR #67).
METRICS_TOKEN=<random-32-byte-hex>

# Allowed CORS origin (or comma-separated list). Boot-crashes in production when unset.
CORS_ORIGIN=https://gravityroom.app

# Public API URL used in OAuth redirects and transactional email links.
# Keep this on the API origin, not the SPA origin.
API_PUBLIC_URL=https://api.gravityroom.app

# ─── Required (analytics) ───────────────────────────────────────────────────

# Shared secret guarding POST /compute. When empty, /compute rejects every request silently.
INTERNAL_SECRET=<random-32-byte-hex>

# ─── Optional (api) ─────────────────────────────────────────────────────────

# Runtime mode. Setting to "production" arms hard-fail checks.
NODE_ENV=production

# Resend configuration for verification and password-reset emails. Email-based
# signup and forgot-password fail closed in production unless both are set.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="Gravity Room <noreply@gravityroom.app>"

# Apple Sign in with Apple Services ID.
# APPLE_CLIENT_ID=com.gravityroom.web

# GitHub OAuth app credentials.
# GITHUB_CLIENT_ID=<github-oauth-client-id>
# GITHUB_CLIENT_SECRET=<github-oauth-client-secret>

# Microsoft identity platform credentials for Microsoft/Outlook sign-in.
# MICROSOFT_CLIENT_ID=<microsoft-application-client-id>
# MICROSOFT_CLIENT_SECRET=<microsoft-client-secret>
# MICROSOFT_TENANT_ID=consumers

# HTTP port for the api server.
# PORT=3001

# Pino log level: trace | debug | info | warn | error | fatal | silent.
# LOG_LEVEL=info

# Redis connection URL. When unset, rate-limit and presence fall back to in-memory stores.
# REDIS_URL=redis://redis:6379

# Sentry DSN for error tracking. captureException is a no-op when unset.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Truthy when behind a reverse proxy (reads X-Forwarded-For for rate limiting).
# TRUSTED_PROXY=true

# Telegram bot token for new-user alerts. Silent no-op when unset.
# TELEGRAM_BOT_TOKEN=<bot-token-from-@BotFather>

# Telegram chat/channel ID for new-user alerts. Silent no-op when unset.
# TELEGRAM_CHAT_ID=-1001234567890

# Access-token lifetime (jose duration string).
# JWT_ACCESS_EXPIRY=15m

# Enables POST /api/auth/dev. Hard-disabled in production regardless of value.
# AUTH_DEV_ROUTE_ENABLED=false

# Exposes /swagger UI and /swagger/json. Hard-disabled in production regardless of value.
# SWAGGER_ENABLED=false

# postgres-js pool max connections.
# DB_POOL_SIZE=50

# Set to literal "false" to disable SSL. Any other value keeps SSL enabled in production.
# DB_SSL=false

# ─── Optional (analytics) ───────────────────────────────────────────────────

# APScheduler interval for compute job.
# COMPUTE_INTERVAL_HOURS=6
