# Development .env for the api service. Copy to apps/backend/api/.env and
# adjust values for your local stack.
#
# All vars marked "required-in-prod" in src/lib/env-validation.ts are listed
# here so newcomers can populate them once and switch NODE_ENV freely.

# ─── Required-in-prod (also required for full local auth flow) ──────────────

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:password@localhost:5432/gzclp

# JWT signing secret. Must be >= 32 chars locally; >= 64 chars in production.
JWT_SECRET=local-dev-secret-change-in-production-min-32-characters

# Web Google OAuth client ID. Required for any auth call to succeed.
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# Comma-separated Google OAuth client IDs accepted by mobile auth endpoints (android,ios,web).
GOOGLE_CLIENT_IDS=<android>.apps.googleusercontent.com,<ios>.apps.googleusercontent.com,<web>.apps.googleusercontent.com

# Bearer token for GET /metrics. Optional in development; required in production (PR #67).
# METRICS_TOKEN=

# Allowed CORS origin.
CORS_ORIGIN=http://localhost:5173

# ─── Optional ───────────────────────────────────────────────────────────────

# HTTP port (default 3001).
PORT=3001

# Pino log level: trace | debug | info | warn | error | fatal | silent.
LOG_LEVEL=info

# Comma-separated UUIDs of admin users for program definition approval. Empty = no admins.
ADMIN_USER_IDS=

# Sentry DSN for error tracking. Leave empty in development.
SENTRY_DSN=

# Set to true when behind a reverse proxy. Reads real client IP from X-Forwarded-For for rate limiting.
TRUSTED_PROXY=

# Telegram new-user notifications (both optional; silent no-op when absent).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
