DATABASE_URL=postgresql://postgres:password@localhost:5432/gzclp
JWT_SECRET=local-dev-secret-change-in-production
CORS_ORIGIN=http://localhost:5173
PORT=3001
LOG_LEVEL=info
ADMIN_USER_IDS= # Comma-separated UUIDs of admin users for program definition approval. Empty = no admins.
SENTRY_DSN= # Optional. Sentry DSN for error tracking. Leave empty in development.
METRICS_TOKEN= # Optional. When set, GET /metrics requires Authorization: Bearer <token>. Required in production.
TRUSTED_PROXY= # Set to true when behind a reverse proxy (Railway/Fastly). Reads real client IP from X-Forwarded-For for rate limiting.

# Telegram new-user notifications (both are optional).
# When either is absent or empty, the notification feature silently no-ops.
# Set both to activate Telegram alerts whenever a new user registers.
TELEGRAM_BOT_TOKEN= # Optional. Bot token from @BotFather (e.g. 123456:ABC-DEF...). Leave empty to disable notifications.
TELEGRAM_CHAT_ID=   # Optional. Numeric chat/channel ID to post into (e.g. -1001234567890). Leave empty to disable notifications.
