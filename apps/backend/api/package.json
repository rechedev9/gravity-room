{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "start": "tsx src/dev-server.ts",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "cd ../../../packages/database && pnpm run db:generate",
    "db:migrate": "cd ../../../packages/database && pnpm run db:migrate",
    "db:studio": "cd ../../../packages/database && pnpm run db:studio",
    "db:deploy": "tsx src/scripts/migrate-deploy.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:update-definitions": "tsx src/scripts/update-program-definitions.ts"
  },
  "dependencies": {
    "@gzclp/domain": "workspace:*",
    "@hono/node-server": "^1",
    "@node-rs/argon2": "^2",
    "bcryptjs": "^2",
    "elysia": "^1.4.25",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "@upstash/redis": "^1.35.5",
    "@upstash/ratelimit": "^2.0.6",
    "@sentry/node": "^10.40.0",
    "@vercel/functions": "^3.7.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6",
    "@gzclp/database": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4",
    "vitest": "^4"
  }
}
